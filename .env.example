# Production Agent 环境变量配置模版

# 1. 核心 LLM API 配置 (必填)
# ------------------------------------------------------------------------------
# API 密钥。严禁将真实的 Key 写入此文件并上传到 GitHub！
ANTHROPIC_API_KEY=your_api_key_here

# 兼容 Anthropic 协议的网关地址 (可选)
# 智谱 AI: https://open.bigmodel.cn/api/anthropic
# 默认: https://api.anthropic.com
ANTHROPIC_BASE_URL=https://api.anthropic.com

# 调用的模型 ID
# 推荐使用: claude-3-5-sonnet-20241022 或 glm-4.7 (智谱)
MODEL_ID=claude-3-5-sonnet-20241022


# 2. MCP 动态工具配置 (JSON 格式)
# ------------------------------------------------------------------------------
# 支持三种传输类型：stdio, sse, http
# 
# stdio: 启动本地子进程 (如 npx, python 等)
# sse:   连接 HTTP Server-Sent Events 端点
# http:  连接 FastMCP HTTP/JSON-RPC 端点
#
# MCP_SERVERS 环境变量优先于 config/mcp_servers.yaml
MCP_SERVERS=[
  {"name":"filesystem","transport":"stdio","command":["npx","-y","@modelcontextprotocol/server-filesystem","./"]},
  {"name":"fastapi_mcp","transport":"http","url":"http://localhost:8000/mcp","timeout":60}
]


# 3. YAML 配置 (替代环境变量方案)
# ------------------------------------------------------------------------------
# 如果 MCP_SERVERS 未设置，则从 config/mcp_servers.yaml 加载
# 参见 config/mcp_servers.yaml 示例


# 4. 进阶配置 (可选)
# ------------------------------------------------------------------------------
# 自定义技能扫描路径。若不配置，则默认扫描 skills/builtin/ 目录。
# SKILLS_PATH=/absolute/path/to/your/custom/skills
