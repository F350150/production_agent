# Production Agent 环境变量配置模版

# 1. 核心 LLM API 配置 (必填)
# ------------------------------------------------------------------------------
# API 密钥。严禁将真实的 Key 写入此文件并上传到 GitHub！
ANTHROPIC_API_KEY=your_api_key_here

# 兼容 Anthropic 协议的网关地址 (可选)
# 智谱 AI: https://open.bigmodel.cn/api/anthropic
# 默认: https://api.anthropic.com
ANTHROPIC_BASE_URL=https://api.anthropic.com

# 调用的模型 ID
# 推荐使用: claude-3-5-sonnet-20241022 或 glm-4.7 (智谱)
MODEL_ID=claude-3-5-sonnet-20241022


# 2. MCP 动态工具配置 (JSON 格式)
# ------------------------------------------------------------------------------
# 示例配置接入了 filesystem (本地文件访问)。
# 你可以根据需要添加 google-search, remote-db 等其他 MCP 服务器。
MCP_SERVERS=[{"name":"filesystem","transport":"stdio","command":["npx","-y","@modelcontextprotocol/server-filesystem","./"]}]


# 3. 进阶配置 (可选)
# ------------------------------------------------------------------------------
# 自定义技能扫描路径。若不配置，则默认扫描 skills/builtin/ 目录。
# SKILLS_PATH=/absolute/path/to/your/custom/skills
